# Azure SQL - never commit .env to git
AZURE_SQL_SERVER=yourserver.database.windows.net
AZURE_SQL_DATABASE=YourDatabaseName
AZURE_SQL_USER=your_username
AZURE_SQL_PASSWORD=your_secure_password
AZURE_SQL_ENCRYPT=true

# API security: use a long random string (e.g. openssl rand -hex 32)
API_SECRET_KEY=your_api_secret_key_here

# Allowed frontend origin (comma-separated for multiple)
CORS_ORIGIN=http://localhost:5173,http://localhost:3000,https://ttp-dashboard.azurestaticapps.net

# Optional: require x-api-key header for all /api requests (set to true in production)
REQUIRE_API_KEY=false

PORT=3001
